# Environment Variables for AntiAI.me

# Database
DATABASE_URL="postgresql://antiai:antiai_dev_password@localhost:5432/antiai?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth (YouTube API)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/oauth/google/callback"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ELITE=""

# Ed25519 Signing Keys (base64 encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SIGNING_KEY_ID="k_2026_01"
SIGNING_PRIVATE_KEY_B64=""
SIGNING_PUBLIC_KEY_B64=""

# App URLs
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Environment
NODE_ENV="development"
