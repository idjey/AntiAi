// This is your Prisma schema file for AntiAI.me
// Based on the specification: Ed25519-only proofs, versioned, immutable, one ACTIVE per video

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

// ==================== ENUMS ====================

enum UserRole {
  creator
  admin
}

enum VerificationStatus {
  pending
  verified
  revoked
}

enum ProofStatus {
  active
  expired
  revoked
  superseded
}

enum ChallengeStatus {
  active
  paused
  expired
}

enum ChallengeType {
  object
  phrase
  object_phrase
}

enum ReportStatus {
  open
  reviewed
  closed
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
}

enum PlanTier {
  free
  pro
  business
  elite
}

// ==================== USERS ====================

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.Citext
  passwordHash      String?   @map("password_hash")
  role              UserRole  @default(creator)
  isEmailVerified   Boolean   @default(false) @map("is_email_verified")
  isSuspended       Boolean   @default(false) @map("is_suspended")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastLoginAt       DateTime? @map("last_login_at")
  otp               String?   @db.VarChar(8)
  otpExpiresAt      DateTime? @map("otp_expires_at")
  failedOtpAttempts Int       @default(0) @map("failed_otp_attempts")
  otpLockedUntil    DateTime? @map("otp_locked_until")

  // Relations
  oauthAccounts     OAuthAccount[]
  channels          Channel[]
  subscription      Subscription?
  auditLogs         AuditLog[]
  reviewedReports   Report[]          @relation("ReviewedBy")
  moderationReviews ModerationQueue[] @relation("ModerationReviewedBy")
  profile           CreatorProfile?
  links             CreatorLink[]
  emailEvents       EmailEvent[]

  @@map("users")
}

// ==================== CREATOR PROFILES (Linktree-style) ====================

model CreatorProfile {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  handle           String    @unique @db.Citext // Custom vanity URL: antiai.me/creators/{handle}
  categories       String[]  @default([]) // Selected categories for directory filtering
  displayName      String?   @map("display_name")
  bio              String?   @db.Text
  avatarUrl        String?   @map("avatar_url")
  bannerUrl        String?   @map("banner_url")
  featuredVideoId  String?   @map("featured_video_id") @db.Uuid
  isPublic         Boolean   @default(true) @map("is_public")
  isFeatured       Boolean   @default(false) @map("is_featured") // Admin override for "Trending Authentic Profiles"
  appearance       Json?     @default("{}") // { theme, primaryColor, backgroundColor, backgroundImageUrl, ... }
  lastHandleChange DateTime? @map("last_handle_change")
  customDomain     String?   @unique @map("custom_domain")
  lastDomainChange DateTime? @map("last_domain_change")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  featuredVideo   Video?           @relation(fields: [featuredVideoId], references: [id], onDelete: SetNull)
  analyticsEvents AnalyticsEvent[]

  @@index([handle])
  @@map("creator_profiles")
}

model CreatorLink {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  label          String // "Website", "Twitter", "Instagram", etc.
  url            String
  icon           String? // Optional icon identifier: "website", "twitter", "instagram", etc.
  customImageUrl String?  @map("custom_image_url")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@map("creator_links")
}

model OAuthAccount {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  provider        String // 'google'
  providerUserId  String    @map("provider_user_id")
  accessTokenEnc  Bytes?    @map("access_token_enc")
  refreshTokenEnc Bytes?    @map("refresh_token_enc")
  tokenExpiry     DateTime? @map("token_expiry")
  scope           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@map("oauth_accounts")
}

// ==================== SIGNING KEYS ====================

model SigningKey {
  id           String    @id // kid, e.g. "k_2026_01"
  alg          String    @default("Ed25519")
  publicKeyB64 String    @map("public_key_b64") // base64 of raw 32-byte Ed25519 public key
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  retiredAt    DateTime? @map("retired_at")

  // Relations
  proofs Proof[]

  @@index([isActive])
  @@map("signing_keys")
}

// ==================== CHANNELS ====================

model Channel {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  platform           String             @default("youtube") // 'youtube', 'tiktok', 'instagram', 'facebook'
  platformId         String             @default("") @map("platform_id")
  channelHandle      String?            @map("channel_handle")
  channelName        String             @map("channel_name")
  channelUrl         String?            @map("channel_url")
  avatarUrl          String?            @map("avatar_url")
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verificationMethod String?            @map("verification_method") // 'oauth' | 'about_token' | 'video_token' | 'pinned_comment'
  verificationToken  String?            @map("verification_token") // Token for non-OAuth verification
  tokenExpiresAt     DateTime?          @map("token_expires_at")
  verifiedAt         DateTime?          @map("verified_at")
  revokedAt          DateTime?          @map("revoked_at")
  revokeReason       String?            @map("revoke_reason")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos     Video[]
  proofs     Proof[]
  challenges Challenge[]
  reports    Report[]

  @@unique([userId, platform, platformId])
  @@unique([platform, platformId])
  @@index([userId])
  @@index([verificationStatus])
  @@map("channels")
}

// ==================== VIDEOS ====================

model Video {
  id           String    @id @default(uuid()) @db.Uuid
  channelId    String    @map("channel_id") @db.Uuid
  platform     String    @default("youtube") // 'youtube', 'tiktok', 'instagram', 'facebook'
  platformId   String    @default("") @map("platform_id")
  title        String?
  videoUrl     String?   @map("video_url")
  thumbnailUrl String?   @map("thumbnail_url")
  publishedAt  DateTime? @map("published_at")
  registeredAt DateTime  @default(now()) @map("registered_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  channel    Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  proofs     Proof[]
  challenges Challenge[]
  reports    Report[]
  featuredBy CreatorProfile[] // Profiles that feature this video
  flags      ContentFlag[]
  context    VideoContext?

  @@unique([platform, platformId])
  @@index([channelId])
  @@index([publishedAt])
  @@map("videos")
}

// ==================== PROOFS ====================

// STRICT RULES:
// - alg must be Ed25519
// - payload_b64 + signature_b64 are immutable for a given row
// - multiple proofs per video allowed
// - only ONE active proof per video enforced via application logic
// - reissue uses supersedesProofId + supersededAt and sets old to 'superseded'

model Proof {
  id        String @id @default(uuid()) @db.Uuid
  videoId   String @map("video_id") @db.Uuid
  channelId String @map("channel_id") @db.Uuid

  // Signing material
  alg String @default("Ed25519")
  kid String // References SigningKey.id

  // Canonical payload & signature (IMMUTABLE after creation)
  payloadJson  Json   @map("payload_json") // stored for debugging/inspection
  payloadB64   String @map("payload_b64") // base64url(canonical JSON bytes)
  signatureB64 String @map("signature_b64") // base64url(Ed25519 signature 64 bytes)

  issuedAt  DateTime    @default(now()) @map("issued_at")
  expiresAt DateTime    @map("expires_at")
  status    ProofStatus @default(active)

  schemaVersion Int     @default(1) @map("schema_version")
  contentHash   String? @map("content_hash")

  // Version lineage for re-issue
  supersedesProofId String?   @unique @map("supersedes_proof_id") @db.Uuid
  supersededAt      DateTime? @map("superseded_at")

  // Revocation (only for security/abuse)
  revokedAt    DateTime? @map("revoked_at")
  revokeReason String?   @map("revoke_reason")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  video           Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  channel         Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  signingKey      SigningKey @relation(fields: [kid], references: [id], onDelete: Restrict)
  supersedesProof Proof?     @relation("ProofSupersedes", fields: [supersedesProofId], references: [id], onDelete: SetNull)
  supersededBy    Proof?     @relation("ProofSupersedes")
  reports         Report[]

  @@index([videoId])
  @@index([channelId])
  @@index([status, expiresAt])
  @@map("proofs")
}

// ==================== CHALLENGES (Optional Layer) ====================

model Challenge {
  id               String          @id // short id for URL
  videoId          String          @map("video_id") @db.Uuid
  channelId        String          @map("channel_id") @db.Uuid
  type             ChallengeType   @default(object)
  objectCode       String?         @map("object_code")
  objectLabel      String?         @map("object_label")
  phrase           String?
  startsAt         DateTime        @default(now()) @map("starts_at")
  expiresAt        DateTime        @map("expires_at")
  status           ChallengeStatus @default(active)
  decoyPoolVersion Int             @default(1) @map("decoy_pool_version")
  createdAt        DateTime        @default(now()) @map("created_at")

  // Relations
  video    Video              @relation(fields: [videoId], references: [id], onDelete: Cascade)
  channel  Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  options  ChallengeOption[]
  attempts ChallengeAttempt[]
  reports  Report[]

  @@index([videoId])
  @@index([channelId])
  @@index([status, expiresAt])
  @@map("challenges")
}

model ChallengeOption {
  id          String  @id @default(uuid()) @db.Uuid
  challengeId String  @map("challenge_id")
  optionCode  String  @map("option_code")
  optionLabel String  @map("option_label")
  isCorrect   Boolean @default(false) @map("is_correct")
  sortOrder   Int     @default(0) @map("sort_order")

  // Relations
  challenge Challenge          @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  attempts  ChallengeAttempt[]

  @@index([challengeId])
  @@map("challenge_options")
}

model ChallengeAttempt {
  id                    String   @id @default(uuid()) @db.Uuid
  challengeId           String   @map("challenge_id")
  selectedOptionId      String?  @map("selected_option_id") @db.Uuid
  isCorrect             Boolean  @map("is_correct")
  ipHash                Bytes?   @map("ip_hash")
  userAgentHash         Bytes?   @map("user_agent_hash")
  deviceFingerprintHash Bytes?   @map("device_fingerprint_hash")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  challenge      Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  selectedOption ChallengeOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@index([challengeId, createdAt(sort: Desc)])
  @@index([ipHash, createdAt(sort: Desc)])
  @@map("challenge_attempts")
}

// ==================== BILLING ====================

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  plan                 PlanTier           @default(free)
  interval             String             @default("month") // 'month' or 'year'
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")

  // Usage tracking
  videosThisMonth  Int      @default(0) @map("videos_this_month")
  usagePeriodStart DateTime @default(now()) @map("usage_period_start")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

// ==================== AUDIT LOGS ====================

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ==================== REPORTS ====================

model Report {
  id             String       @id @default(uuid()) @db.Uuid
  channelId      String?      @map("channel_id") @db.Uuid
  videoId        String?      @map("video_id") @db.Uuid
  proofId        String?      @map("proof_id") @db.Uuid
  challengeId    String?      @map("challenge_id")
  reporterIpHash Bytes?       @map("reporter_ip_hash")
  reason         String
  details        String?
  status         ReportStatus @default(open)
  createdAt      DateTime     @default(now()) @map("created_at")
  reviewedAt     DateTime?    @map("reviewed_at")
  reviewedById   String?      @map("reviewed_by") @db.Uuid

  // Relations
  channel    Channel?   @relation(fields: [channelId], references: [id], onDelete: SetNull)
  video      Video?     @relation(fields: [videoId], references: [id], onDelete: SetNull)
  proof      Proof?     @relation(fields: [proofId], references: [id], onDelete: SetNull)
  challenge  Challenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  reviewedBy User?      @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@map("reports")
}

// ==================== TRANSPARENCY LOG ====================

model TransparencyLog {
  id         String   @id @default(uuid()) @db.Uuid
  eventType  String   @map("event_type")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  data       Json
  eventTime  DateTime @default(now()) @map("event_time")

  @@index([entityType, entityId])
  @@index([eventTime(sort: Desc)])
  @@map("transparency_log")
}

// ==================== ANALYTICS ====================

model AnalyticsEvent {
  id        String  @id @default(uuid()) @db.Uuid
  creatorId String  @map("creator_id") @db.Uuid // Owner of the profile/link
  type      String // 'view' | 'click'
  entityId  String? @map("entity_id") // Link ID (for clicks) or Profile ID (for views)
  // Visitor Info
  ipHash    String? @map("ip_hash") // Anonymized
  country   String?
  region    String? // State/Province
  city      String?
  device    String? // 'mobile', 'desktop', 'tablet'
  os        String?
  browser   String?
  referer   String?

  // Engagement Info
  scrollDepth     Int? @map("scroll_depth") // 0-100 percentage
  sessionDuration Int? @map("session_duration") // seconds

  // Marketing UTMs
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  creator CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
  @@index([type, createdAt])
  @@map("analytics_events")
}

// ==================== MODERATION ====================

model ModerationQueue {
  id           String    @id @default(uuid()) @db.Uuid
  targetType   String    @map("target_type") // 'profile', 'channel', 'video'
  targetId     String    @map("target_id") @db.Uuid
  payload      Json // { old: {}, new: {} }
  status       String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reason       String?
  createdAt    DateTime  @default(now()) @map("created_at")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewedById String?   @map("reviewed_by") @db.Uuid

  // Relations
  reviewedBy User? @relation("ModerationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@map("moderation_queue")
}

model SystemSetting {
  key         String   @id
  value       String?
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ==================== SYSTEM OBSERVABILITY ====================

model SystemAlert {
  id       String @id @default(uuid()) @db.Uuid
  type     String // e.g. 'VIRAL_VELOCITY'
  severity String // 'info', 'warning', 'critical'
  message  String
  data     Json? // { creatorId: "...", baseline: 5, current: 80 }

  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([type, createdAt(sort: Desc)])
  @@index([readAt])
  @@map("system_alerts")
}

// ==================== COUPONS ====================

model Coupon {
  id             String    @id @default(uuid()) @db.Uuid
  code           String    @unique // e.g. "WELCOME25", "SPRING2026"
  description    String?
  discountType   String    @map("discount_type") // 'percentage' | 'fixed'
  discountValue  Float     @map("discount_value") // 25 = 25% or 5.00 = $5
  maxRedemptions Int?      @map("max_redemptions") // null = unlimited
  currentUses    Int       @default(0) @map("current_uses")
  isActive       Boolean   @default(true) @map("is_active")
  expiresAt      DateTime? @map("expires_at")
  stripeCouponId String?   @map("stripe_coupon_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive, expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id          String    @id @default(uuid()) @db.Uuid
  couponId    String    @map("coupon_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  email       String? // For visitor leads (pre-signup)
  source      String    @default("manual") // 'signup' | 'lead' | 'admin_send' | 'manual' | 'checkout'
  emailSentAt DateTime? @map("email_sent_at") // When the coupon email was sent
  usedAt      DateTime  @default(now()) @map("used_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@index([source])
  @@map("coupon_redemptions")
}

// ==================== CROWDSOURCED INTELLIGENCE ====================

model ContentFlag {
  id        String   @id @default(uuid()) @db.Uuid
  videoId   String   @map("video_id") @db.Uuid // Foreign key to Video.id
  userId    String?  @map("user_id") @db.Uuid // Optional: ID of the user flagging it
  ipHash    Bytes?   @map("ip_hash")
  reason    String // E.g., "Deepfake", "Voice Clone"
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now()) @map("created_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@map("content_flags")
}

model VideoContext {
  id         String   @id @default(uuid()) @db.Uuid
  videoId    String   @unique @map("video_id") @db.Uuid // Foreign key to Video.id
  note       String // The public "Community Note"
  approvedBy String   @map("approved_by") @db.Uuid // Admin ID who approved it
  createdAt  DateTime @default(now()) @map("created_at")

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@map("video_contexts")
}

// ==================== EMAIL MARKETING ====================

model EmailCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  subject         String
  htmlContent     String    @map("html_content") @db.Text
  status          String    @default("draft") // 'draft', 'scheduled', 'sending', 'sent', 'failed'
  audienceSegment String    @map("audience_segment") // e.g. 'all', 'elite_only', 'free_only', 'custom'
  customEmails    String?   @map("custom_emails") @db.Text // Comma-separated emails for 'custom' segment
  scheduledAt     DateTime? @map("scheduled_at")
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  events EmailEvent[]

  @@index([status])
  @@index([scheduledAt])
  @@map("email_campaigns")
}

model EmailTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  htmlContent String   @map("html_content") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model EmailEvent {
  id         String   @id @default(uuid()) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  email      String
  eventType  String   @map("event_type") // 'sent', 'delivered', 'open', 'click', 'bounce', 'spamreport'
  createdAt  DateTime @default(now()) @map("created_at")

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([userId])
  @@index([email])
  @@map("email_events")
}
