{
  "icons": {
    "16": "./gen-assets/icon16.plasmo.png",
    "32": "./gen-assets/icon32.plasmo.png",
    "48": "./gen-assets/icon48.plasmo.png",
    "64": "./gen-assets/icon64.plasmo.png",
    "128": "./gen-assets/icon128.plasmo.png"
  },
  "manifest_version": 2,
  "browser_action": {
    "default_icon": {
      "16": "./gen-assets/icon16.plasmo.png",
      "32": "./gen-assets/icon32.plasmo.png",
      "48": "./gen-assets/icon48.plasmo.png",
      "64": "./gen-assets/icon64.plasmo.png",
      "128": "./gen-assets/icon128.plasmo.png"
    },
    "default_popup": "./popup.html"
  },
  "version": "0.0.1",
  "author": "AntiAI",
  "name": "AntiAI",
  "description": "AntiAI Browser Extension",
  "background": {
    "scripts": [
      "./static/background/index.ts"
    ]
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "https://*.youtube.com/*",
    "http://localhost:4000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "..\\content.ts"
      ],
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "antiai@antiai.me",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
