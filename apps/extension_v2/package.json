{
    "name": "antiai-extension",
    "displayName": "AntiAI",
    "version": "0.0.1",
    "description": "AntiAI Browser Extension",
    "author": "AntiAI",
    "scripts": {
        "dev": "plasmo dev",
        "build": "plasmo build",
        "package": "plasmo package",
        "dev:firefox": "plasmo dev --target=firefox-mv2",
        "build:firefox": "plasmo build --target=firefox-mv2",
        "dev:edge": "plasmo dev --target=edge-mv3",
        "build:edge": "plasmo build --target=edge-mv3",
        "dev:opera": "plasmo dev --target=opera-mv3",
        "build:opera": "plasmo build --target=opera-mv3",
        "dev:brave": "plasmo dev --target=brave-mv3",
        "build:brave": "plasmo build --target=brave-mv3"
    },
    "dependencies": {
        "clsx": "^2.0.0",
        "framer-motion": "^10.12.16",
        "lucide-react": "^0.263.1",
        "plasmo": "latest",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "tailwind-merge": "^1.14.0"
    },
    "devDependencies": {
        "@types/chrome": "^0.1.36",
        "@types/node": "^20.19.33",
        "@types/react": "18.2.0",
        "@types/react-dom": "18.2.0",
        "autoprefixer": "^10.4.14",
        "postcss": "^8.4.27",
        "tailwindcss": "^3.3.3",
        "typescript": "5.2.2"
    },
    "manifest": {
        "browser_specific_settings": {
            "gecko": {
                "id": "antiai@antiai.me",
                "data_collection_permissions": {
                    "required": [
                        "none"
                    ]
                }
            }
        },
        "host_permissions": [
            "https://*.youtube.com/*",
            "http://localhost:4000/*",
            "https://*.antiai.me/*",
            "https://antiaiapi-production.up.railway.app/*"
        ],
        "permissions": [
            "tabs",
            "storage",
            "activeTab"
        ]
    }
}