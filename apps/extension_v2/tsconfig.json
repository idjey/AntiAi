{
    "compilerOptions": {
        "target": "esnext",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "~*": [
                "./*"
            ]
        },
        "types": [
            "chrome",
            "node"
        ]
    },
    "include": [
        ".plasmo/t7-shim.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "*.d.ts",
        ".plasmo/index.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}