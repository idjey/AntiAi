{
  "name": "antiai",
  "version": "0.1.0",
  "private": true,
  "description": "AntiAI.me - Authenticity verification platform for creators",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run generate -w packages/database",
    "db:push": "npm run push -w packages/database",
    "db:migrate": "npm run migrate -w packages/database",
    "db:studio": "npm run studio -w packages/database"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}