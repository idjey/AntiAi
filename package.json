{
  "name": "antiai",
  "version": "0.1.0",
  "private": true,
  "description": "AntiAI.me - Authenticity verification platform for creators",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:packages": "npm run build -w packages/shared -w packages/crypto -w packages/database -w packages/attestation-core",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && npm run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run generate -w packages/database",
    "db:push": "npm run push -w packages/database",
    "db:migrate": "npm run migrate -w packages/database",
    "db:studio": "npm run studio -w packages/database"
  },
  "devDependencies": {
    "@types/ioredis-mock": "^8.2.7",
    "@types/jest": "^29.5.12",
    "concurrently": "^9.2.1",
    "fast-check": "^4.9.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prop-types": "^15.8.1"
  },
  "packageManager": "npm@10.8.1"
}
